        "# Generalized linear models\n",
        "\n",
        "\n",
        "\n",
        "\n",
        "::: {.hidden}\n",
        "<!-- Constants and basic symbols -->\n",
        "\n",
        "$$\n",
        "\\require{physics}\n",
        "\\require{braket}\n",
        "$$\n",
        "\n",
