    "def forward_selection(data, response, candidates):\n",
    "    remaining = list(candidates)\n",
    "    selected = []\n",
    "    current_aic = np.inf\n",
    "    history = []\n",
    "\n",
    "    while remaining:\n",
    "        scored = []\n",
    "        for term in remaining:\n",
    "            formula = f\"{response} ~ {' + '.join(selected + [term])}\"\n",
    "            fit = smf.ols(formula, data=data).fit()\n",
    "            scored.append((fit.aic, term, fit))\n",
    "        scored.sort(key=lambda x: x[0])\n",
    "        best_aic, best_term, best_fit = scored[0]\n",
    "        if best_aic + 1e-8 < current_aic:\n",
    "            selected.append(best_term)\n",
    "            remaining.remove(best_term)\n",
    "            current_aic = best_aic\n",
    "            history.append((best_term, best_aic))\n",
    "        else:\n",
    "            break\n",
    "\n",
    "    return selected, current_aic, pd.DataFrame(history, columns=[\"added_term\", \"aic\"])\n",
    "\n",
    "\n",
    "candidate_terms = [\n",
    "    \"horsepower\",\n",
    "    \"weight\",\n",
    "    \"acceleration\",\n",
    "    \"C(origin)\",\n",
    "    \"C(cylinders)\",\n",
    "]\n",
    "\n",
    "selected_terms, selected_aic, stepwise_path = forward_selection(\n",
    "    mpg, \"mpg\", candidate_terms\n",
    ")\n",
    "\n",
    "print(\"Selected terms:\", selected_terms)\n",
    "print(\"Final AIC:\", selected_aic)\n",
    "stepwise_path"
   ]
