    "fit_metrics = fit_categorical\n",
    "y = fit_metrics.model.endog\n",
    "n = fit_metrics.nobs\n",
    "p = fit_metrics.df_model + 1\n",
    "\n",
    "sse = np.sum(fit_metrics.resid ** 2)\n",
    "sst = np.sum((y - y.mean()) ** 2)\n",
    "mse = sse / fit_metrics.df_resid\n",
    "r2 = 1 - sse / sst\n",
    "adj_r2 = 1 - (sse / fit_metrics.df_resid) / (sst / (n - 1))\n",
    "aic = fit_metrics.aic\n",
    "bic = fit_metrics.bic\n",
    "cp = mallows_cp(fit_metrics, sigma2_full)\n",
    "press = np.sum(\n",
