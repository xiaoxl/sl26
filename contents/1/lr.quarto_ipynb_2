      "source": [
        "import itertools\n",
        "\n",
        "import matplotlib.pyplot as plt\n",
        "import numpy as np\n",
        "import pandas as pd\n",
        "import seaborn as sns\n",
        "import statsmodels.api as sm\n",
        "import statsmodels.formula.api as smf\n",
        "from statsmodels.stats.anova import anova_lm\n",
        "\n",
        "mpg = sns.load_dataset(\"mpg\").dropna()\n",
        "mpg[\"origin\"] = mpg[\"origin\"].astype(\"category\")\n",
        "mpg[\"cylinders\"] = mpg[\"cylinders\"].astype(\"category\")\n",
        "mpg[\"hp2\"] = mpg[\"horsepower\"] ** 2\n",
        "mpg[\"wt2\"] = mpg[\"weight\"] ** 2\n",
        "\n",
        "response = \"mpg\"\n",
        "predictors = [\"horsepower\", \"weight\", \"acceleration\"]\n",
        "\n",
        "mpg[[\"mpg\", \"horsepower\", \"weight\", \"acceleration\", \"origin\", \"cylinders\"]].head()"
      ],
      "id": "2ebcb256",
      "execution_count": null,
      "outputs": []
    },
    {
      "cell_type": "markdown",
      "metadata": {},
      "source": [
        "### Fit a Basic Model"
      ],
      "id": "9e3df5a6"
    },
    {
      "cell_type": "code",
      "metadata": {},
      "source": [
        "fit_linear = smf.ols(\n",
        "    \"mpg ~ horsepower + weight + acceleration\",\n",
        "    data=mpg,\n",
        ").fit()\n",
        "\n",
        "print(fit_linear.summary())"
      ],
      "id": "459fda5f",
      "execution_count": null,
      "outputs": []
    },
    {
      "cell_type": "markdown",
      "metadata": {},
      "source": [
        "### Fit a Higher-Degree Model"
      ],
      "id": "4438adac"
    },
    {
      "cell_type": "code",
      "metadata": {},
      "source": [
        "fit_poly = smf.ols(\n",
        "    \"mpg ~ horsepower + I(horsepower**2) + weight + I(weight**2) + acceleration\",\n",
        "    data=mpg,\n",
        ").fit()\n",
        "\n",
        "print(fit_poly.summary())"
      ],
      "id": "b6180c7d",
      "execution_count": null,
      "outputs": []
    },
    {
      "cell_type": "markdown",
      "metadata": {},
      "source": [
        "### Fit a Model With Interactions"
      ],
      "id": "700f86b5"
    },
    {
      "cell_type": "code",
      "metadata": {},
      "source": [
        "fit_interaction = smf.ols(\n",
        "    \"mpg ~ horsepower * weight + acceleration\",\n",
        "    data=mpg,\n",
        ").fit()\n",
        "\n",
        "print(fit_interaction.summary())"
      ],
      "id": "1b3993b3",
      "execution_count": null,
      "outputs": []
    },
    {
      "cell_type": "markdown",
      "metadata": {},
      "source": [
        "### Fit a Model With Categorical Variables"
      ],
      "id": "207339f5"
    },
    {
      "cell_type": "code",
      "metadata": {},
      "source": [
        "fit_categorical = smf.ols(\n",
        "    \"mpg ~ horsepower + weight + acceleration + C(origin) + C(cylinders)\",\n",
        "    data=mpg,\n",
        ").fit()\n",
        "\n",
        "print(fit_categorical.summary())"
      ],
      "id": "50bb01c3",
      "execution_count": null,
      "outputs": []
    },
    {
      "cell_type": "markdown",
      "metadata": {},
      "source": [
        "### Generate a Summary Table"
      ],
      "id": "12021e38"
    },
    {
      "cell_type": "code",
      "metadata": {},
      "source": [
        "summary_table = fit_categorical.summary2().tables[1].copy()\n",
        "summary_table[\"CI 2.5%\"] = fit_categorical.conf_int()[0]\n",
        "summary_table[\"CI 97.5%\"] = fit_categorical.conf_int()[1]\n",
        "summary_table"
      ],
      "id": "1489ad91",
      "execution_count": null,
      "outputs": []
    },
    {
      "cell_type": "markdown",
      "metadata": {},
      "source": [
        "### Generate ANOVA Tables: Type I, II, and III\n",
        "\n",
        "Type I sums of squares depend on the order in which the terms enter the model. Type II and Type III tables are order-invariant under the usual model-coding assumptions, but they answer slightly different questions."
      ],
      "id": "3bba1ff7"
    },
    {
      "cell_type": "code",
      "metadata": {},
      "source": [
        "fit_anova = smf.ols(\n",
        "    \"mpg ~ horsepower + weight + acceleration + C(origin)\",\n",
        "    data=mpg,\n",
        ").fit()\n",
        "\n",
        "print(\"Type I ANOVA\")\n",
        "print(anova_lm(fit_anova, typ=1))\n",
        "\n",
        "print(\"\\nType II ANOVA\")\n",
        "print(anova_lm(fit_anova, typ=2))\n",
        "\n",
        "print(\"\\nType III ANOVA\")\n",
        "print(anova_lm(fit_anova, typ=3))"
      ],
      "id": "a154c15c",
      "execution_count": null,
      "outputs": []
    },
    {
      "cell_type": "markdown",
      "metadata": {},
      "source": [
        "### Generate a Nested ANOVA Table\n",
        "\n",
        "Nested ANOVA compares a smaller model with a larger model that contains all of its terms plus additional predictors."
      ],
      "id": "ca3d5e99"
    },
    {
      "cell_type": "code",
      "metadata": {},
      "source": [
        "fit_nested_small = smf.ols(\"mpg ~ horsepower + weight\", data=mpg).fit()\n",
        "fit_nested_large = smf.ols(\n",
        "    \"mpg ~ horsepower + weight + acceleration + C(origin)\",\n",
        "    data=mpg,\n",
        ").fit()\n",
        "\n",
        "anova_lm(fit_nested_small, fit_nested_large)"
      ],
      "id": "dc38b6b7",
      "execution_count": null,
      "outputs": []
    },
    {
      "cell_type": "markdown",
      "metadata": {},
      "source": [
        "### Residual Plots"
      ],
      "id": "f30ccfab"
    },
    {
      "cell_type": "code",
      "metadata": {},
      "source": [
        "diagnostics = mpg[[\"mpg\", \"horsepower\", \"weight\", \"acceleration\", \"origin\"]].copy()\n",
        "diagnostics[\"fitted\"] = fit_categorical.fittedvalues\n",
        "diagnostics[\"resid\"] = fit_categorical.resid\n",
        "diagnostics[\"student_resid\"] = fit_categorical.get_influence().resid_studentized_internal\n",
